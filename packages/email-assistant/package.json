{
  "name": "@kit/email-assistant",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "clean": "git clean -xdf .turbo node_modules",
    "format": "prettier --check \"**/*.{ts,md,json}\"",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
