{
  "$schema": "https://turborepo.org/schema.json",
  "globalDependencies": [
    "**/.env"
  ],
  "ui": "stream",
  "globalEnv": [
    "STRIPE_SECRET_KEY",
    "STRIPE_WEBHOOK_SECRET",
    "STRIPE_CONNECT_CLIENT_ID",
    "STRIPE_CONNECT_WEBHOOK_SECRET",
    "STRIPE_INVOICE_WEBHOOK_SECRET",
    "STRIPE_BILLING_CURRENCY",
    "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY",
    "NEXT_PUBLIC_PRODUCT_NAME",
    "NEXT_PUBLIC_SITE_URL",
    "NEXT_PUBLIC_SITE_TITLE",
    "NEXT_PUBLIC_SITE_DESCRIPTION",
    "NEXT_PUBLIC_DEFAULT_THEME_MODE",
    "NEXT_PUBLIC_THEME_COLOR",
    "NEXT_PUBLIC_THEME_COLOR_DARK",
    "NEXT_PUBLIC_DEFAULT_LOCALE",
    "NEXT_PUBLIC_AUTH_PASSWORD",
    "NEXT_PUBLIC_AUTH_MAGIC_LINK",
    "NEXT_PUBLIC_AUTH_OTP",
    "NEXT_PUBLIC_AUTH_IDENTITY_LINKING",
    "NEXT_PUBLIC_CAPTCHA_SITE_KEY",
    "NEXT_PUBLIC_DISPLAY_TERMS_AND_CONDITIONS_CHECKBOX",
    "NEXT_PUBLIC_BILLING_PROVIDER",
    "NEXT_PUBLIC_ENABLE_THEME_TOGGLE",
    "NEXT_PUBLIC_ENABLE_PERSONAL_ACCOUNT_DELETION",
    "NEXT_PUBLIC_ENABLE_TEAM_ACCOUNTS_DELETION",
    "NEXT_PUBLIC_ENABLE_TEAM_ACCOUNTS",
    "NEXT_PUBLIC_ENABLE_TEAM_ACCOUNTS_CREATION",
    "NEXT_PUBLIC_ENABLE_PERSONAL_ACCOUNT_BILLING",
    "NEXT_PUBLIC_ENABLE_TEAM_ACCOUNTS_BILLING",
    "NEXT_PUBLIC_ENABLE_NOTIFICATIONS",
    "NEXT_PUBLIC_REALTIME_NOTIFICATIONS",
    "NEXT_PUBLIC_ENABLE_VERSION_UPDATER",
    "NEXT_PUBLIC_LANGUAGE_PRIORITY",
    "NEXT_PUBLIC_MONITORING_PROVIDER",
    "EMAIL_SENDER",
    "EMAIL_PORT",
    "EMAIL_HOST",
    "EMAIL_TLS",
    "EMAIL_USER",
    "EMAIL_PASSWORD",
    "CMS_CLIENT",
    "LOGGER",
    "LEMON_SQUEEZY_SECRET_KEY",
    "LEMON_SQUEEZY_SIGNING_SECRET",
    "LEMON_SQUEEZY_STORE_ID",
    "KEYSTATIC_STORAGE_KIND",
    "KEYSTATIC_STORAGE_PROJECT",
    "KEYSTATIC_STORAGE_REPO",
    "KEYSTATIC_STORAGE_BRANCH_PREFIX",
    "KEYSTATIC_PATH_PREFIX",
    "KEYSTATIC_GITHUB_TOKEN",
    "NEXT_PUBLIC_KEYSTATIC_STORAGE_REPO",
    "NEXT_PUBLIC_KEYSTATIC_CONTENT_PATH",
    "NEXT_PUBLIC_KEYSTATIC_STORAGE_KIND",
    "WORDPRESS_API_URL",
    "SUPABASE_DB_WEBHOOK_SECRET",
    "INSTRUMENTATION_SERVICE_NAME",
    "NEXT_PUBLIC_SENTRY_DSN",
    "CAPTCHA_SECRET_TOKEN",
    "NEXT_PUBLIC_BASELIME_KEY",
    "NEXT_PUBLIC_SUPABASE_URL",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY",
    "SUPABASE_URL",
    "SUPABASE_SERVICE_ROLE_KEY",
    "SUPABASE_SECRET_KEY",
    "ENABLE_BILLING_TESTS",
    "RESEND_API_KEY",
    "MAILER_PROVIDER",
    "CONTACT_EMAIL",
    "AZURE_CLIENT_ID",
    "AZURE_CLIENT_SECRET",
    "AZURE_SECRET_VALUE",
    "AZURE_REDIRECT_URI",
    "GOOGLE_SERVICE_ACCOUNT_JSON",
    "GOOGLE_SERVICE_ACCOUNT_EMAIL",
    "GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY",
    "DATAFORSEO_LOGIN",
    "DATAFORSEO_PASSWORD",
    "ANTHROPIC_API_KEY",
    "ANTHROPIC_MODEL",
    "ANTHROPIC_BRIEF_MODEL",
    "ANTHROPIC_AUDIT_MODEL",
    "ANTHROPIC_TASK_EXTRACT_MODEL",
    "CRON_SECRET",
    "QUICK_ACTION_SECRET",
    "TOKEN_ENCRYPTION_KEY",
    "OAUTH_STATE_SECRET",
    "GOOGLE_PAGESPEED_API_KEY",
    "GOOGLE_TOKEN_ENC_KEY",
    "GOOGLE_GMAIL_CLIENT_ID",
    "GOOGLE_GMAIL_CLIENT_SECRET",
    "GOOGLE_GMAIL_REDIRECT_URI",
    "BUNNY_STREAM_API_KEY",
    "BUNNY_STREAM_LIBRARY_ID",
    "BUNNY_STREAM_CDN_HOSTNAME",
    "BUNNY_WEBHOOK_SECRET",
    "OPENPAGERANK_API_KEY",
    "FREEAGENT_CLIENT_ID",
    "FREEAGENT_CLIENT_SECRET",
    "AWS_REGION",
    "AWS_ACCESS_KEY_ID",
    "AWS_SECRET_ACCESS_KEY",
    "SUPPORT_INBOX",
    "NEXT_PUBLIC_SUPABASE_PUBLIC_KEY",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY"
  ],
  "tasks": {
    "topo": {
      "dependsOn": [
        "^topo"
      ]
    },
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "next-env.d.ts"
      ]
    },
    "@kit/mcp-server#build": {
      "outputs": [
        "build/**"
      ]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "format": {
      "outputs": [
        "node_modules/.cache/.prettiercache"
      ],
      "outputLogs": "new-only"
    },
    "lint": {
      "dependsOn": [
        "^topo"
      ],
      "outputs": [
        "node_modules/.cache/.eslintcache"
      ]
    },
    "typecheck": {
      "dependsOn": [
        "^topo"
      ],
      "outputs": [
        "node_modules/.cache/tsbuildinfo.json"
      ]
    },
    "test": {
      "dependsOn": [
        "^topo"
      ]
    },
    "clean": {
      "cache": false
    },
    "//#clean": {
      "cache": false
    },
    "license#dev": {
      "outputLogs": "errors-only"
    }
  }
}
