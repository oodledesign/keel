{
  "type": "YbbScallopSection",
  "label": "YBB Scallop section",
  "category": "ybb",
  "fields": [
    { "key": "sectionId", "type": "text", "label": "Section ID (anchor)" },
    {
      "key": "overlapPrevious",
      "type": "boolean",
      "label": "Overlap previous section (hero scallop join)"
    },
    { "key": "scriptLine", "type": "text", "label": "Background script line" },
    {
      "key": "headingBefore",
      "type": "text",
      "label": "Heading — before accent"
    },
    {
      "key": "headingAccent",
      "type": "text",
      "label": "Heading — accent phrase"
    },
    {
      "key": "headingAfter",
      "type": "text",
      "label": "Heading — after accent"
    },
    { "key": "body", "type": "textarea", "label": "Body copy" },
    { "key": "photoLeftUrl", "type": "image", "label": "Left photo" },
    { "key": "photoRightUrl", "type": "image", "label": "Right photo" },
    { "key": "photoAccentUrl", "type": "image", "label": "Accent photo" },
    {
      "key": "bandBackgroundToken",
      "type": "select",
      "label": "Band background",
      "options": [
        { "label": "Primary brand", "value": "primary" },
        { "label": "Secondary brand", "value": "secondary" },
        { "label": "Accent", "value": "accent" },
        { "label": "Custom colour", "value": "custom" }
      ]
    },
    {
      "key": "bandBackgroundColor",
      "type": "color",
      "label": "Custom band colour"
    },
    {
      "key": "scallopFillToken",
      "type": "select",
      "label": "Scallop bottom fill",
      "options": [
        { "label": "Atmosphere (N2)", "value": "atmosphere" },
        { "label": "Surface (N1)", "value": "surface" },
        { "label": "Canvas (N0)", "value": "canvas" },
        { "label": "Custom colour", "value": "custom" }
      ]
    },
    {
      "key": "scallopFillColor",
      "type": "color",
      "label": "Custom scallop fill"
    },
    { "key": "showPrimaryCta", "type": "boolean", "label": "Show primary CTA" },
    { "key": "primaryCtaLabel", "type": "text", "label": "Primary CTA label" },
    { "key": "primaryCtaHref", "type": "link", "label": "Primary CTA link" },
    {
      "key": "primaryCtaVariant",
      "type": "select",
      "label": "Primary CTA style",
      "options": [
        { "label": "Primary (filled)", "value": "primary" },
        { "label": "Secondary (outline)", "value": "secondary" },
        { "label": "Tertiary (accent fill)", "value": "tertiary" },
        { "label": "Text link", "value": "text" }
      ]
    },
    {
      "key": "showSecondaryCta",
      "type": "boolean",
      "label": "Show secondary CTA"
    },
    {
      "key": "secondaryCtaLabel",
      "type": "text",
      "label": "Secondary CTA label"
    },
    {
      "key": "secondaryCtaHref",
      "type": "link",
      "label": "Secondary CTA link"
    },
    {
      "key": "secondaryCtaVariant",
      "type": "select",
      "label": "Secondary CTA style",
      "options": [
        { "label": "Primary (filled)", "value": "primary" },
        { "label": "Secondary (outline)", "value": "secondary" },
        { "label": "Tertiary (accent fill)", "value": "tertiary" },
        { "label": "Text link", "value": "text" }
      ]
    }
  ],
