{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd ../.. && pnpm run build --filter=web",
  "installCommand": "cd ../.. && pnpm install",
  "crons": [
    {
      "path": "/api/cron/rankly-rank-check",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/rankly-rank-check-worker",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/rankly-site-crawl-worker",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/rankly-pagespeed",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/finance-freeagent-sync",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/billing-trial-reminders",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/billing-dunning-reminders",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/personal-people-reminders",
      "schedule": "0 7 * * *"
    }
  ]
}
