    "./draft": "./src/draft.ts"
  },
  "dependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {
    "@kit/eslint-config": "workspace:*",
    "@kit/prettier-config": "workspace:*",
    "@kit/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
