# Copy to apps/web/.env.local for local secrets (never commit .env.local).
# Shared public vars live in apps/web/.env — see content/documentation/getting-started/quick-start.mdoc

# ---------------------------------------------------------------------------
# Bunny.net Stream — Video Hosting module
# ---------------------------------------------------------------------------
# Account-level Stream API key (Stream > your library > API in Bunny dashboard).
# Each library also has its own key; use the key for the library you upload to.
BUNNY_STREAM_API_KEY=

# Default Bunny Stream library ID (overridable per account later).
BUNNY_STREAM_LIBRARY_ID=

# CDN hostname for thumbnails, e.g. vz-xxxxxxxx.b-cdn.net (Stream library > CDN).
BUNNY_STREAM_CDN_HOSTNAME=

# Shared secret for validating inbound Bunny webhooks (set the same value in Bunny).
BUNNY_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Open PageRank — Rankly domain authority (free API key from domcop.com/openpagerank)
# ---------------------------------------------------------------------------
OPENPAGERANK_API_KEY=

# ---------------------------------------------------------------------------
# AWS Athena — Common Crawl backlink queries (Rankly)
# One-time: create cc_link_graph table in Athena console (see INTEGRATION-commoncrawl.md)
# ---------------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
ATHENA_RESULTS_BUCKET=s3://rankly-athena-results/
ATHENA_DATABASE=ccindex
