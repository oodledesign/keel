{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd ../.. && pnpm run build --filter=web",
  "installCommand": "cd ../.. && pnpm install",
  "build": {
    "env": {
      "NODE_OPTIONS": "--max-old-space-size=5120",
      "NEXT_WEBPACK_PARALLELISM": "1",
      "ENABLE_STRICT_CSP": "true"
    }
  },
  "crons": [
    {
      "path": "/api/cron/rankly-rank-check",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/rankly-rank-check-worker",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/rankly-site-crawl-worker",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/rankly-pagespeed",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/finance-freeagent-sync",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/billing-trial-reminders",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/billing-dunning-reminders",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/personal-people-reminders",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/planner-reminders",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/project-phase-due-reminders",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/brain-reindex-active",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/gmail/sync",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/ai/batch/submit",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/ai/batch/poll",
      "schedule": "0 */2 * * *"
    }
  ]
}
