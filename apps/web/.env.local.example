# Copy to apps/web/.env.local for local secrets (never commit .env.local).
# Shared public vars live in apps/web/.env — see content/documentation/getting-started/quick-start.mdoc

# ---------------------------------------------------------------------------
# Bunny.net Stream — Video Hosting module
# ---------------------------------------------------------------------------
# Account-level Stream API key (Stream > your library > API in Bunny dashboard).
# Each library also has its own key; use the key for the library you upload to.
BUNNY_STREAM_API_KEY=

# Default Bunny Stream library ID (overridable per account later).
BUNNY_STREAM_LIBRARY_ID=

# CDN hostname for thumbnails, e.g. vz-xxxxxxxx.b-cdn.net (Stream library > CDN).
BUNNY_STREAM_CDN_HOSTNAME=

# Shared secret for validating inbound Bunny webhooks (set the same value in Bunny).
BUNNY_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Keel platform billing (Stripe — GBP workspace subscriptions)
# Create matching products/prices in Stripe Dashboard, then paste Price IDs here.
# ---------------------------------------------------------------------------
STRIPE_BILLING_CURRENCY=GBP
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Workspace base plans
STRIPE_PRICE_COMMUNITY_MONTHLY=
STRIPE_PRICE_COMMUNITY_YEARLY=
STRIPE_PRICE_BUSINESS_SOLO_MONTHLY=
STRIPE_PRICE_BUSINESS_SOLO_YEARLY=
STRIPE_PRICE_BUSINESS_TEAM_MONTHLY=
STRIPE_PRICE_BUSINESS_TEAM_YEARLY=
STRIPE_PRICE_BUSINESS_SCALE_MONTHLY=
STRIPE_PRICE_BUSINESS_SCALE_YEARLY=
STRIPE_PRICE_PROPERTY_STARTER_MONTHLY=
STRIPE_PRICE_PROPERTY_STARTER_YEARLY=
STRIPE_PRICE_PROPERTY_PORTFOLIO_MONTHLY=
STRIPE_PRICE_PROPERTY_PORTFOLIO_YEARLY=

# Add-ons (per workspace)
STRIPE_PRICE_ADDON_RANKLY_MONTHLY=
STRIPE_PRICE_ADDON_FEEDFLOW_MONTHLY=
STRIPE_PRICE_ADDON_VIDEOS_STARTER_MONTHLY=
STRIPE_PRICE_ADDON_VIDEOS_GROWTH_MONTHLY=
STRIPE_PRICE_ADDON_VIDEOS_PRO_MONTHLY=
STRIPE_PRICE_ADDON_VIDEOS_STUDIO_MONTHLY=

# Optional: 14-day trial without card (default requires card)
# STRIPE_ENABLE_TRIAL_WITHOUT_CC=false

# Optional: separate signing secret for quick actions / OAuth
# QUICK_ACTION_SECRET=

# ---------------------------------------------------------------------------
# Email (Amazon SES via @kit/ses mailer)
# Local dev: keep MAILER_PROVIDER=nodemailer and Inbucket (see .env.development).
# Production: MAILER_PROVIDER=ses with verified domain/address in SES.
# ---------------------------------------------------------------------------
MAILER_PROVIDER=ses
EMAIL_SENDER="Keel <support@yourdomain.com>"
SUPPORT_INBOX=support@yourdomain.com
CONTACT_EMAIL=support@yourdomain.com
NEXT_PUBLIC_SITE_URL=https://app.yourdomain.com
# HMAC secret for campaign view-in-browser links (falls back to SUPABASE_JWT_SECRET)
CAMPAIGN_EMAIL_SIGNING_SECRET=

# SES uses the same AWS credentials as other AWS integrations (e.g. Athena).
# AWS_REGION=eu-west-2
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# Optional override: SES_REGION=eu-west-1

# Legacy / local SMTP (MAILER_PROVIDER=nodemailer only)
# EMAIL_HOST=email-smtp.eu-west-1.amazonaws.com
# EMAIL_PORT=587
# EMAIL_TLS=true
# EMAIL_USER=
# EMAIL_PASSWORD=

# Do not use Resend — Keel sends via Amazon SES.
# RESEND_API_KEY=

# ---------------------------------------------------------------------------
# Open PageRank — Rankly domain authority (free API key from domcop.com/openpagerank)
# ---------------------------------------------------------------------------
OPENPAGERANK_API_KEY=

# ---------------------------------------------------------------------------
# AWS Athena — Common Crawl backlink queries (Rankly)
# One-time: create cc_link_graph table in Athena console (see INTEGRATION-commoncrawl.md)
# ---------------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
ATHENA_RESULTS_BUCKET=s3://rankly-athena-results/
ATHENA_DATABASE=ccindex
